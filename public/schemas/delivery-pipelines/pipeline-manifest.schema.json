{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/delivery-pipelines/pipeline-manifest.schema.json",
  "title": "PipelineManifest",
  "type": "object",
  "required": ["name", "service", "versioning", "stages"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 3 },
    "service": {
      "type": "object",
      "required": ["id", "ownerTeam"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9\\-]+$" },
        "ownerTeam": { "type": "string", "minLength": 2 },
        "runtime": { "type": "string", "enum": ["node", "python", "java", "go", "dotnet", "other"] }
      }
    },
    "versioning": {
      "type": "object",
      "required": ["strategy"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["semver", "calver", "git-sha"] },
        "tagPrefix": { "type": "string" }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "steps"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9\\-]+$" },
          "type": { "type": "string", "enum": ["build", "test", "scan", "release", "deploy"] },
          "environment": {
            "type": "string",
            "description": "Optional environment target for deploy stages."
          },
          "requiresApproval": { "type": "boolean", "default": false },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "run"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "run": { "type": "string", "description": "Shell command or script reference." },
                "timeoutMinutes": { "type": "integer", "minimum": 1 },
                "artifacts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "name": { "type": "string" },
                      "path": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
